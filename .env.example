# App
NODE_ENV=development
PORT=3000
APP_BASE_URL=https://chat.example.com

# CORS
WIDGET_ALLOWED_ORIGINS=https://example.com,https://www.example.com
SOCKET_CORS_ORIGIN=https://example.com

# Database
